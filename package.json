{
  "name": "codex-spur",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "dev:app": "tauri dev",
    "bundle:dmg": "tauri build --bundles dmg",
    "site:dev": "vite --config website/vite.config.ts --host 127.0.0.1",
    "site:typecheck": "tsc -p website/tsconfig.json --noEmit --pretty false",
    "site:build": "node website/scripts/validate-release.mjs && npm run site:typecheck && vite --config website/vite.config.ts build",
    "site:preview": "vite preview --config website/vite.config.ts",
    "site:deploy": "bash website/scripts/deploy.sh",
    "bundle:macos": "tauri build --bundles dmg",
    "bundle:nsis": "tauri build --bundles nsis",
    "bundle:windows": "tauri build --bundles nsis"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
